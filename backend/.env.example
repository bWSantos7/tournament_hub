# ============================================================
# Tournament Hub — Environment Variables Reference
# Copy this file to .env and fill in your values.
# All variables marked [REQUIRED] will cause the app to refuse
# to start if not set, preventing accidental insecure deploys.
# ============================================================

# ─── Django Core ────────────────────────────────────────────
# [REQUIRED] Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=False

# Comma-separated list of allowed host headers
# Railway example: api.tournamenthub.app,yourservice.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ───────────────────────────────────────────────
# [REQUIRED] PostgreSQL only — SQLite is rejected at startup
# Railway provides this automatically when you attach a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis / Celery ─────────────────────────────────────────
# Railway provides this automatically when you attach a Redis service
REDIS_URL=redis://default:password@host:6379

# ─── CORS & CSRF ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.tournamenthub.app
CSRF_TRUSTED_ORIGINS=https://app.tournamenthub.app,https://api.tournamenthub.app

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Email (Resend) ─────────────────────────────────────────
# Get key at resend.com — leave empty to fall back to console logging
RESEND_API_KEY=re_...
# Use onboarding@resend.dev until your domain is verified in Resend
DEFAULT_FROM_EMAIL=no-reply@tournamenthub.app
RESEND_FROM_EMAIL=no-reply@tournamenthub.app

# ─── Cloudinary ─────────────────────────────────────────────
# Get from cloudinary.com → Dashboard → API Keys
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://...

# ─── Frontend URL ───────────────────────────────────────────
FRONTEND_URL=https://app.tournamenthub.app

# ─── Web Push (VAPID) ───────────────────────────────────────
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=no-reply@tournamenthub.app

# ─── Asaas Payments ─────────────────────────────────────────
# sandbox: use $aact_... key from sandbox.asaas.com
# production: use $aact_... key from app.asaas.com
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
# Must match the token configured in Asaas Webhook settings
ASAAS_WEBHOOK_TOKEN=

# ─── Sentry ─────────────────────────────────────────────────
# Get DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
# Optional: git SHA or semver tag for release tracking
SENTRY_RELEASE=

# ─── Scraper ────────────────────────────────────────────────
SCRAPER_USER_AGENT=TournamentHubBot/1.0
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT_SECONDS=2

# ─── SSL (Railway handles SSL termination externally) ────────
# Keep False on Railway — SSL redirect is done at the proxy level
SECURE_SSL_REDIRECT=False
